# Copy this file to `.env` for LOCAL testing only. `.env` is gitignored.
# In production these three live in GitHub -> Settings -> Secrets and variables -> Actions.

# From Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# From @BotFather in Telegram (create a bot, it gives you the token)
TELEGRAM_BOT_TOKEN=

# Ipshita's chat id. She messages the bot once, then:
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
# and read result[].message.chat.id
TELEGRAM_CHAT_ID=

# Optional: Adzuna gives real India job coverage. Free keys: developer.adzuna.com
# Skipped automatically if left blank.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional: Reddit blocks anonymous requests from CI IPs, so the Reddit section
# needs a free "script" app (reddit.com/prefs/apps) -> client id + secret.
# Left blank = Reddit section is simply skipped.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: Tavily LLM-grade web search (free tier at tavily.com) — surfaces
# real current listings from across the web. Left blank = skipped.
TAVILY_API_KEY=

# --- optional knobs (sensible defaults, leave blank to use them) ---
# GEMINI_MODEL=gemini-3.5-flash
# MAX_ITEMS=10
# DRY_RUN=false        # true = print the digest instead of sending to Telegram
# SEND_WHEN_EMPTY=false # true = send a "nothing new today" note on quiet days
