# Copy this file to `.env` for LOCAL testing only. `.env` is gitignored.
# In production these three live in GitHub -> Settings -> Secrets and variables -> Actions.

# From Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# From @BotFather in Telegram (create a bot, it gives you the token)
TELEGRAM_BOT_TOKEN=

# Ipshita's chat id. She messages the bot once, then:
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
# and read result[].message.chat.id
TELEGRAM_CHAT_ID=

# --- optional knobs (sensible defaults, leave blank to use them) ---
# GEMINI_MODEL=gemini-2.5-flash
# MAX_ITEMS=10
# DRY_RUN=false        # true = print the digest instead of sending to Telegram
# SEND_WHEN_EMPTY=false # true = send a "nothing new today" note on quiet days
