---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** 'article' for blog posts — switches Open Graph type + enables article meta */
  type?: 'website' | 'article';
  publishedDate?: Date;
  tags?: string[];
  /** JSON-LD structured data blocks rendered into <head> */
  schema?: Record<string, unknown>[];
}

const {
  title,
  description = 'Sankalp Chaturvedi — software developer building Python/FastAPI backends, Elasticsearch data pipelines, and agentic AI systems.',
  type = 'website',
  publishedDate,
  tags = [],
  schema = [],
} = Astro.props;

const site = Astro.site ?? new URL('https://snklp.dev');
// one canonical form: no trailing slash (except the root)
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const canonical = new URL(path, site).href;
const ogImage = new URL('/og.png', site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Sankalp Chaturvedi" />
    <meta name="theme-color" content="#0b0b1e" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Sankalp Chaturvedi — Dev Log"
      href="/rss.xml"
    />

    <!-- Open Graph / social share -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Sankalp Chaturvedi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Retro arcade start screen: Sankalp Chaturvedi — software developer, press start."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {
      type === 'article' && publishedDate && (
        <meta property="article:published_time" content={publishedDate.toISOString()} />
      )
    }
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    {schema.map((block) => <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />)}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="hud">
      <div class="wrap hud__inner">
        <a href="/#top" class="hud__logo" aria-label="Home">SC</a>
        <nav class="hud__nav" aria-label="Main">
          <a href="/#world-1">EXP</a>
          <a href="/#world-2">QUESTS</a>
          <a href="/#world-3">SKILLS</a>
          <a href="/blog">DEV&nbsp;LOG</a>
          <a href="/#continue">CONTACT</a>
        </nav>
        <button class="hud__coins" id="coin-btn" title="Insert coin">
          <i class="coin" aria-hidden="true"></i>
          <span>×<span id="coin-count">00</span></span>
        </button>
      </div>
    </header>

    <main id="top">
      <slot />
    </main>

    <footer class="footer">
      <p class="display">GAME OVER? NEVER. — CONTINUE (9)</p>
      <p>
        © 2026 Sankalp Chaturvedi · built with Astro · original pixel art, no
        plumbers were licensed
      </p>
    </footer>

    <script>
      // Coin counter easter egg — persists between visits.
      const btn = document.getElementById('coin-btn');
      const out = document.getElementById('coin-count');
      const KEY = 'sc-coins';

      const render = (n: number) => {
        if (out) out.textContent = String(n).padStart(2, '0');
      };

      let coins = Number(localStorage.getItem(KEY) ?? 0);
      render(coins);

      const addCoins = (n: number) => {
        coins += n;
        localStorage.setItem(KEY, String(coins));
        render(coins);
      };

      btn?.addEventListener('click', () => addCoins(1));

      // ↑ ↑ ↓ ↓ ← → ← → B A — you know what this is.
      const KONAMI = [
        'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
        'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
        'b', 'a',
      ];
      let step = 0;

      const toast = (msg: string) => {
        document.querySelector('.toast')?.remove();
        const el = document.createElement('div');
        el.className = 'toast display';
        el.setAttribute('role', 'status');
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 2800);
      };

      window.addEventListener('keydown', (e) => {
        const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
        step = key === KONAMI[step] ? step + 1 : key === KONAMI[0] ? 1 : 0;
        if (step === KONAMI.length) {
          step = 0;
          addCoins(30);
          toast('+30 LIVES · CHEAT ACCEPTED. RESPECT.');
        }
      });
    </script>
  </body>
</html>
