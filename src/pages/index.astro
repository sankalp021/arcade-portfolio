---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = posts.slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });

const siteUrl = (Astro.site ?? new URL('https://snklp.dev')).href;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sankalp Chaturvedi',
  url: siteUrl,
  jobTitle: 'Software Developer',
  worksFor: { '@type': 'Organization', name: 'Photonmatters' },
  email: 'mailto:snklp021@gmail.com',
  sameAs: [
    'https://github.com/sankalp021',
    'https://www.linkedin.com/in/sankalp-chaturvedi-567315233/',
  ],
  knowsAbout: [
    'Python',
    'FastAPI',
    'Elasticsearch',
    'Kibana',
    'Agentic AI',
    'RAG',
    'LLM integration',
    'Vector databases',
    'React',
    'Next.js',
    'Node.js',
    'Docker',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Sankalp Chaturvedi — Arcade Portfolio',
  url: siteUrl,
  description:
    'Portfolio and dev log of Sankalp Chaturvedi, a software developer working on backends, data pipelines, and agentic AI.',
  author: { '@type': 'Person', name: 'Sankalp Chaturvedi' },
};
---

<Base
  title="Sankalp Chaturvedi — Software Developer | Backend, Data & Agentic AI"
  description="Portfolio and dev log of Sankalp Chaturvedi — software developer building Python/FastAPI backends, Elasticsearch data pipelines, and agentic AI systems at Photonmatters."
  schema={[personSchema, websiteSchema]}
>
  <!-- ============ HERO / ATTRACT SCREEN ============ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero__hiscore" aria-label="Stats">
        <span>1UP <b>SANKALP</b></span>
        <span>WORLDS <b>05</b></span>
        <span>SIDE QUESTS <b>02</b></span>
        <span>HI-SCORE <b>SIH TOP 5</b></span>
      </div>

      <p class="hero__player">PLAYER ONE</p>
      <h1 class="hero__title">SANKALP CHATURVEDI</h1>
      <p class="hero__sub">SOFTWARE DEVELOPER · BACKEND · DATA · AGENTIC AI</p>

      <button class="hero__start" id="press-start">▶ PRESS START</button>
      <p class="hero__hint">BOT RUN — SPACE OR TAP TO JUMP · MIND THE BUGS</p>
    </div>

    <!-- original pixel bot, ambling across the ground -->
    <svg class="walker" width="48" height="48" viewBox="0 0 16 16" aria-hidden="true">
      <!-- antenna -->
      <rect x="7" y="0" width="2" height="2" fill="#ff4d4d" />
      <!-- head -->
      <rect x="4" y="2" width="8" height="5" fill="#ffd23f" />
      <rect x="5" y="3" width="2" height="2" fill="#0b0b1e" />
      <rect x="9" y="3" width="2" height="2" fill="#0b0b1e" />
      <!-- body -->
      <rect x="3" y="7" width="10" height="5" fill="#4dd8ff" />
      <rect x="6" y="8" width="4" height="3" fill="#0b0b1e" />
      <rect x="7" y="9" width="2" height="1" fill="#45e06f" />
      <!-- legs, two frames toggled by CSS -->
      <g class="legA">
        <rect x="4" y="12" width="2" height="4" fill="#ffd23f" />
        <rect x="10" y="12" width="2" height="4" fill="#ffd23f" />
      </g>
      <g class="legB">
        <rect x="5" y="12" width="2" height="4" fill="#ffd23f" />
        <rect x="9" y="12" width="2" height="4" fill="#ffd23f" />
      </g>
    </svg>
    <canvas
      class="run-canvas"
      id="run-canvas"
      height="200"
      role="img"
      aria-label="BOT RUN mini-game: jump over the bugs with space or tap"></canvas>
    <div class="ground" aria-hidden="true"></div>
  </section>

  <!-- ============ WORLD 1 · EXPERIENCE ============ -->
  <div class="dots" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
  <section class="world wrap" id="world-1">
    <p class="world__label">WORLD 1</p>
    <h2 class="world__title">EXPERIENCE</h2>

    <article class="level pixel-border">
      <div class="level__head">
        <span class="level__tag">LEVEL 1-3 · NOW PLAYING</span>
        <h3 class="level__role">Software Developer — Photonmatters</h3>
        <span class="level__meta">Aug 2025 – Present</span>
      </div>
      <ul>
        <li>
          Build and maintain reporting systems on Elasticsearch + Kibana:
          automated reports, dashboards, and data pipelines for large-scale
          financial datasets.
        </li>
        <li>
          Develop scalable Python/FastAPI backends for report generation,
          dynamic filtering, aggregations, and Elasticsearch-based retrieval.
        </li>
        <li>
          Built backend components for agentic AI workflows and a Bank
          Statement Analyzer that turns unstructured financial data into
          structured, decision-ready output.
        </li>
      </ul>
    </article>

    <article class="level pixel-border">
      <div class="level__head">
        <span class="level__tag level__tag--done">LEVEL 1-2 · CLEARED</span>
        <h3 class="level__role">Fullstack Developer Intern — Dozti</h3>
        <span class="level__meta">May 2024 – Oct 2024</span>
      </div>
      <ul>
        <li>
          Built responsive, high-traffic web apps with React, Vite, and
          Tailwind, improving performance and engagement across devices.
        </li>
        <li>
          Integrated REST APIs with Node/Express and contributed to Docker +
          Git deployment pipelines.
        </li>
      </ul>
    </article>

    <article class="level pixel-border">
      <div class="level__head">
        <span class="level__tag level__tag--done">LEVEL 1-1 · CLEARED</span>
        <h3 class="level__role">ERP Developer Intern — Knighthood</h3>
        <span class="level__meta">Feb 2024 – Mar 2024</span>
      </div>
      <ul>
        <li>
          Customized ERPNext/Frappe with modules for attendance, payroll, and
