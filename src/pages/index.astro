      </div>

      <div class="badge pixel-border">
        <svg class="badge__icon" width="36" height="36" viewBox="0 0 8 8" aria-hidden="true">
          <circle cx="4" cy="3" r="2.4" fill="#4dd8ff" />
          <rect x="2" y="5" width="1" height="3" fill="#ff4d4d" />
          <rect x="5" y="5" width="1" height="3" fill="#ff4d4d" />
        </svg>
        <div>
          <p class="badge__unlock">ACHIEVEMENT UNLOCKED · 2023</p>
          <h3 class="badge__name">METABYTE HACKATHON — GLOBAL RANK 2</h3>
          <p>Second place worldwide.</p>
        </div>
      </div>

      <div class="badge pixel-border">
        <svg class="badge__icon" width="36" height="36" viewBox="0 0 8 8" aria-hidden="true">
          <rect x="3" y="0" width="2" height="2" fill="#ffd23f" />
          <rect x="0" y="3" width="8" height="2" fill="#ffd23f" />
          <rect x="2" y="5" width="4" height="1" fill="#ffd23f" />
          <rect x="1" y="6" width="2" height="2" fill="#ffd23f" />
