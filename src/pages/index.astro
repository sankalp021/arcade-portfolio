  <!-- ============ WORLD 4 · ACHIEVEMENTS ============ -->
  <div class="dots" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
  <section class="world wrap" id="world-4">
    <p class="world__label">WORLD 4</p>
    <h2 class="world__title">ACHIEVEMENTS</h2>

    <div class="badges">
