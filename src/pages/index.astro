        href="https://github.com/sankalp021"
        target="_blank"
        rel="noopener noreferrer">GITHUB</a
      >
      <a
        class="btn btn--ghost"
        href="https://www.linkedin.com/in/sankalp-chaturvedi-567315233/"
        target="_blank"
        rel="noopener noreferrer">LINKEDIN</a
      >
    </div>
  </section>

  <script>
    // ================= BOT RUN =================
    // PRESS START (or Space, with the hero on screen) starts the run.
    // Jump the bugs — the developer's natural enemy — and grab coins;
    // they bank into the HUD counter.
    const startBtn = document.getElementById('press-start');
    const canvas = document.getElementById('run-canvas') as HTMLCanvasElement | null;
    const hero = document.querySelector<HTMLElement>('.hero');

    if (startBtn && canvas && hero) {
      const ctx = canvas.getContext('2d')!;
      const C = {
        bg: '#0b0b1e', gold: '#ffd23f', red: '#ff4d4d', green: '#45e06f',
        cyan: '#4dd8ff', ink: '#f2f0e4', muted: '#8f8fb8', bronze: '#b8860b',
      };
      const U = 3; // one game "pixel" — matches the 48px walker sprite
      const H = 200;

      type Px = [number, number, number, number, string];
      // same art as the SVG walker, as drawable rects
      const BOT: Px[] = [
        [7, 0, 2, 2, C.red], [4, 2, 8, 5, C.gold], [5, 3, 2, 2, C.bg],
        [9, 3, 2, 2, C.bg], [3, 7, 10, 5, C.cyan], [6, 8, 4, 3, C.bg],
        [7, 9, 2, 1, C.green],
      ];
      const LEGS_A: Px[] = [[4, 12, 2, 4, C.gold], [10, 12, 2, 4, C.gold]];
      const LEGS_B: Px[] = [[5, 12, 2, 4, C.gold], [9, 12, 2, 4, C.gold]];
      const BUG: Px[] = [
        [1, 0, 1, 1, C.red], [6, 0, 1, 1, C.red],
        [1, 1, 6, 3, C.red], [2, 2, 1, 1, C.ink], [5, 2, 1, 1, C.ink],
        [1, 4, 1, 2, C.green], [3, 4, 1, 2, C.green], [5, 4, 1, 2, C.green],
      ];
      const COIN: Px[] = [
        [2, 0, 4, 1, C.bronze], [1, 1, 6, 6, C.gold], [2, 7, 4, 1, C.bronze],
        [3, 2, 2, 4, C.bronze],
      ];

      const BOT_W = 16 * U;
      const BOT_H = 16 * U;
      const BOT_X = 48;
      const BUG_W = 8 * U;
      const BUG_H = 6 * U;
      const COIN_W = 8 * U;

      let playing = false;
      let over = false;
      let raf = 0;
      let frame = 0;
      let botY = 0; // height above ground
      let vy = 0;
      let speed = 0;
      let score = 0;
      let spawnIn = 0;
      let banked = 0;
      let items: { x: number; kind: 'bug' | 'coin' }[] = [];
      let hi = Number(localStorage.getItem('sc-run-hi') ?? 0);

      const coinOut = document.getElementById('coin-count');
      const bankCoin = () => {
        banked += 1;
        const n = Number(localStorage.getItem('sc-coins') ?? 0) + 1;
        localStorage.setItem('sc-coins', String(n));
        if (coinOut) coinOut.textContent = String(n).padStart(2, '0');
      };

      const sprite = (px: Px[], x: number, y: number) => {
        for (const [sx, sy, w, h, color] of px) {
          ctx.fillStyle = color;
          ctx.fillRect(x + sx * U, y + sy * U, w * U, h * U);
        }
      };

      const resize = () => {
        canvas.width = hero.clientWidth;
        canvas.height = H;
        ctx.imageSmoothingEnabled = false;
      };

      const drawFrame = () => {
        ctx.clearRect(0, 0, canvas.width, H);

        for (const it of items) {
          if (it.kind === 'bug') sprite(BUG, it.x, H - BUG_H);
          else sprite(COIN, it.x, H - 108);
        }

        const legs = botY > 0 ? LEGS_A : frame % 12 < 6 ? LEGS_A : LEGS_B;
        sprite(BOT.concat(legs), BOT_X, H - BOT_H - botY);

        ctx.fillStyle = C.muted;
        ctx.font = '9px "Press Start 2P", monospace';
        ctx.textAlign = 'left';
        ctx.fillText('ESC QUITS', 12, 18);
        ctx.textAlign = 'right';
        ctx.fillStyle = C.gold;
        ctx.fillText(
          `SCORE ${String(Math.floor(score)).padStart(5, '0')}  HI ${String(hi).padStart(5, '0')}`,
          canvas.width - 12,
          18
        );

        if (over) {
          ctx.textAlign = 'center';
          ctx.fillStyle = C.red;
          ctx.font = '18px "Press Start 2P", monospace';
          ctx.fillText('GAME OVER', canvas.width / 2, 84);
          ctx.fillStyle = C.ink;
          ctx.font = '9px "Press Start 2P", monospace';
          ctx.fillText(
            `SCORE ${Math.floor(score)}${banked ? ` · ${banked} COIN${banked > 1 ? 'S' : ''} BANKED` : ''}`,
            canvas.width / 2,
            112
          );
          ctx.fillStyle = C.muted;
          ctx.fillText('SPACE OR TAP TO RETRY', canvas.width / 2, 136);
        }
      };

      const loop = () => {
        frame += 1;
        speed = Math.min(11, speed + 0.0012);
        score += speed * 0.033;

        vy -= 0.8;
        botY = Math.max(0, botY + vy);
        if (botY === 0) vy = 0;

        for (const it of items) it.x -= speed;
        items = items.filter((it) => it.x > -60);

        spawnIn -= 1;
        if (spawnIn <= 0) {
          items.push({
            x: canvas.width + 40,
            kind: Math.random() < 0.22 ? 'coin' : 'bug',
          });
          spawnIn = 46 + Math.random() * 75 - Math.min(26, speed * 2.2);
        }

        // collisions (forgiving hitboxes — arcade games cheat in your favor)
        const botL = BOT_X + 10;
        const botR = BOT_X + BOT_W - 10;
        const botBottom = botY;
        const botTop = botY + BOT_H - 8;
        for (const it of items) {
          if (it.kind === 'bug') {
            const hit =
              it.x + 4 < botR && it.x + BUG_W - 4 > botL && botBottom < BUG_H - 4;
            if (hit) {
              over = true;
              hi = Math.max(hi, Math.floor(score));
              localStorage.setItem('sc-run-hi', String(hi));
            }
          } else {
            const coinBottom = 108 - COIN_W; // height band of the coin
            const grabbed =
              it.x < botR && it.x + COIN_W > botL &&
              botTop > coinBottom && botBottom < 108;
            if (grabbed) {
              it.x = -999;
              bankCoin();
            }
          }
        }

        drawFrame();
        if (!over) raf = requestAnimationFrame(loop);
      };

      const jump = () => {
        if (botY === 0) vy = 13.5;
      };

      const start = () => {
        playing = true;
        over = false;
        frame = 0;
        botY = 0;
        vy = 0;
        speed = 5;
        score = 0;
        banked = 0;
        spawnIn = 50;
        items = [];
        resize();
        canvas.classList.add('is-on');
        hero.classList.add('hero--playing');
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(loop);
      };

      const quit = () => {
        playing = false;
        over = false;
        cancelAnimationFrame(raf);
        canvas.classList.remove('is-on');
        hero.classList.remove('hero--playing');
      };

      startBtn.addEventListener('click', start);

      canvas.addEventListener('pointerdown', () => {
        if (!playing) return;
        if (over) start();
        else jump();
      });

      const heroOnScreen = () =>
        hero.getBoundingClientRect().bottom > window.innerHeight * 0.5;

      window.addEventListener('keydown', (e) => {
        if (!playing) {
          // Space is a start button too — but only while the hero is on screen,
          // so it never hijacks scrolling further down the page.
          if (e.key === ' ' && heroOnScreen()) {
            e.preventDefault();
            start();
          }
          return;
        }
        if (e.key === ' ' || e.key === 'ArrowUp') {
          e.preventDefault();
          if (over) start();
          else jump();
        } else if (e.key === 'Escape') {
          quit();
        }
      });

      window.addEventListener('resize', () => {
        if (playing) resize();
      });
    }
  </script>
</Base>
