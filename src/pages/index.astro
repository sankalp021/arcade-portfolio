      <article class="cabinet cabinet--empty pixel-border">
        <p>INSERT<br />CARTRIDGE<br /><span class="t-muted">next build loading…</span></p>
      </article>
    </div>
  </section>

  <!-- ============ WORLD 3 · SKILLS ============ -->
  <div class="dots" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
  <section class="world wrap" id="world-3">
    <p class="world__label">WORLD 3</p>
    <h2 class="world__title">POWER-UPS</h2>

    <div class="powerups">
      <div class="powerup pixel-border">
        <svg width="32" height="32" viewBox="0 0 8 8" aria-hidden="true">
