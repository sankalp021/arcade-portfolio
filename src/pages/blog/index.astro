---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: '2-digit' });

const siteUrl = (Astro.site ?? new URL('https://snklp.dev')).href;

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Dev Log — Sankalp Chaturvedi',
  url: new URL('/blog', siteUrl).href,
  description:
    'Research notes and write-ups by Sankalp Chaturvedi — backend engineering, data pipelines, agentic AI, and whatever else is currently under investigation.',
  author: { '@type': 'Person', name: 'Sankalp Chaturvedi', url: siteUrl },
};
---

<Base
  title="Dev Log — Sankalp Chaturvedi"
  description="Research notes and write-ups by Sankalp Chaturvedi — backend engineering, data pipelines, agentic AI, and whatever else is currently under investigation."
  schema={[blogSchema]}
>
  <section class="world wrap">
    <p class="world__label">ARCHIVE</p>
    <h1 class="world__title">DEV LOG — ALL ENTRIES</h1>
    <p class="t-muted" style="margin: -14px 0 26px;">
      Anything researched here gets written up here. Scope: unbounded.
    </p>

    {
      posts.map((post) => (
        <a class="log-entry pixel-border" href={`/blog/${post.id}`}>
          <span class="log-entry__date">{fmt(post.data.date)}</span>
          <h2 class="log-entry__title">{post.data.title}</h2>
          <p>{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="log-entry__tags">
              {post.data.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))
    }

    {posts.length === 0 && <p class="t-muted">No entries yet. The log awaits.</p>}
  </section>
</Base>
